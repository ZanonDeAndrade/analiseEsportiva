{
  "name": "betintel-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "BetIntel AI — plataforma acadêmica de análise probabilística de futebol com persistência PostgreSQL.",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --env-file-if-exists=.env.local scripts/dev.mjs",
    "frontend:dev": "node --env-file-if-exists=.env --env-file-if-exists=.env.local node_modules/vite/bin/vite.js --config frontend/vite.config.ts",
    "build": "npm run frontend:build && npm run backend:build",
    "lint": "eslint .",
    "typecheck": "npm run frontend:typecheck && npm run backend:typecheck",
    "frontend:typecheck": "tsc -b frontend/tsconfig.app.json frontend/tsconfig.node.json",
    "backend:typecheck": "tsc -p backend/tsconfig.json --noEmit",
    "test:unit": "npm run backend:test && npm run test:frontend",
    "test:frontend": "vitest run --config frontend/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep \"@a11y\"",
    "test:integration": "npm run backend:build && node --test \"backend/dist/infrastructure/database/**/*.test.js\"",
    "test:evals": "node --test \"evals/*.test.mjs\"",
    "frontend:build": "tsc -b && node --env-file-if-exists=.env --env-file-if-exists=.env.local node_modules/vite/bin/vite.js build --config frontend/vite.config.ts",
    "preview": "node --env-file-if-exists=.env --env-file-if-exists=.env.local node_modules/vite/bin/vite.js preview --config frontend/vite.config.ts",
    "backend:build": "tsc -p backend/tsconfig.json",
    "backend:test": "npm run backend:build && node --test \"backend/dist/**/*.test.js\"",
    "backend:sync": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local backend/dist/cli/sync-data.js",
    "backend:train": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local backend/dist/cli/train.js",
    "backend:evaluate": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local backend/dist/cli/evaluate.js",
    "backend:backtest": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local backend/dist/cli/backtest.js",
    "backend:train:offline": "npm run backend:build && node backend/dist/cli/train.js --csv backend/data/combined-results.csv",
    "backend:evaluate:offline": "npm run backend:build && node backend/dist/cli/evaluate.js --csv backend/data/combined-results.csv",
    "backend:backtest:offline": "npm run backend:build && node backend/dist/cli/backtest.js --csv backend/data/combined-results.csv",
    "backend:pipeline:offline": "npm run backend:train:offline && npm run backend:evaluate:offline",
    "db:generate": "node --env-file-if-exists=.env --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs generate",
    "db:check": "node --env-file-if-exists=.env --env-file-if-exists=.env.local node_modules/drizzle-kit/bin.cjs check",
    "db:migrate": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local backend/dist/cli/migrate.js",
    "db:import": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local backend/dist/cli/import-local-state.js",
    "db:test": "npm run backend:build && node --test \"backend/dist/infrastructure/database/**/*.test.js\"",
    "backend:serve": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local --import ./backend/dist/telemetry/instrumentation.js backend/dist/server.js",
    "backend:worker": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local --import ./backend/dist/telemetry/instrumentation.js backend/dist/worker.js",
    "backend:scheduler": "npm run backend:build && node --env-file-if-exists=.env --env-file-if-exists=.env.local --import ./backend/dist/telemetry/instrumentation.js backend/dist/scheduler.js",
    "smoke": "node scripts/smoke-test.mjs",
    "backup:drill": "docker compose -f compose.dev.yaml --profile disaster-recovery run --rm restore-drill",
    "alert:drill": "node scripts/alert-drill.mjs",
    "docker:build": "docker build --pull --tag betintel-ai:local ."
  },
  "dependencies": {
    "@auth0/auth0-react": "^2.21.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@sentry/node": "^10.65.0",
    "auth0": "^6.0.0",
    "bullmq": "^5.80.4",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sentry/cli": "^3.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.12.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.4.11",
    "vitest": "^3.2.7"
  }
}
