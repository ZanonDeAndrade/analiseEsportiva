API_FOOTBALL_KEY=
# Referencias definidas pelo responsavel pelo deploy; a aplicacao nao conclui
# se a licenca permite o uso. Configure apos revisao interna do contrato/fonte.
API_FOOTBALL_USE_POLICY_REFERENCE=
API_FOOTBALL_LICENSE_REFERENCE=
API_FOOTBALL_ALLOWED_ENVIRONMENTS=development
FOOTBALL_DATA_USE_POLICY_REFERENCE=
FOOTBALL_DATA_LICENSE_REFERENCE=
FOOTBALL_DATA_ALLOWED_ENVIRONMENTS=development
BETINTEL_ENABLE_FOOTBALL_DATA=false
# API v4 de fixtures. Obtenha o token na sua propria conta e mantenha-o somente no servidor.
FOOTBALL_DATA_ORG_API_KEY=
FOOTBALL_DATA_ORG_USE_POLICY_REFERENCE=
FOOTBALL_DATA_ORG_LICENSE_REFERENCE=
FOOTBALL_DATA_ORG_ALLOWED_ENVIRONMENTS=development
NODE_ENV=development
BETINTEL_ENVIRONMENT=development
BETINTEL_BACKEND_HOST=127.0.0.1
BETINTEL_BACKEND_PORT=3333
DATABASE_URL=postgresql://betintel:change-me@127.0.0.1:5432/betintel
# Em producao, use um papel dedicado sem SUPERUSER e sem BYPASSRLS.
DATABASE_POOL_MAX=10
BETINTEL_API_HISTORY_YEARS=5
BETINTEL_SYNC_API_HISTORY=true
# Janela rolante de jogos: hoje ate hoje + N dias (padrao 7). Atualiza sozinho a cada dia.
BETINTEL_FIXTURE_DAYS=7
# Opcional: data final fixa (YYYY-MM-DD). Se definida, tem prioridade sobre BETINTEL_FIXTURE_DAYS.
# BETINTEL_FIXTURE_TO=2026-12-31

# Auth0: use tenants e applications separados por ambiente.
AUTH0_DOMAIN=seu-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.betintel.example/v1
AUTH0_SPA_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_ID=
AUTH0_MANAGEMENT_CLIENT_SECRET=
AUTH0_SESSION_ID_CLAIM=https://betintel.ai/session_id
AUTH0_AUTH_TIME_CLAIM=https://betintel.ai/auth_time
CORS_ALLOWED_ORIGINS=http://localhost:5173
REQUEST_IP_HASH_KEY=
# 32 bytes aleatorios em base64; mantenha versoes antigas durante rotacao/recriptografia.
PII_FIELD_ENCRYPTION_KEY=
PII_FIELD_ENCRYPTION_KEY_VERSION=v1
# Auth0 subjects exatos autorizados ao control plane; nao confundir com owner de tenant.
PLATFORM_ADMIN_SUBJECTS=

# Stripe Billing: permanece desligado até todas as validações e os IDs do
# ambiente estarem preenchidos. Nunca use sk_live_ em desenvolvimento/staging.
STRIPE_BILLING_ENABLED=false
# Permite bloquear somente novas vendas mantendo portal e webhooks ativos.
STRIPE_CHECKOUT_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BRASILEIRAO_MONTHLY=
STRIPE_PRICE_TODAS_LIGAS_MONTHLY=
STRIPE_PRICE_BRASILEIRAO_YEARLY=
STRIPE_PRICE_TODAS_LIGAS_YEARLY=
# Opcional; sem valor, usa a configuração padrão do Customer Portal no Stripe.
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=
STRIPE_AUTOMATIC_TAX_ENABLED=false
BILLING_APP_URL=http://localhost:5173
# Referência interna ao go comercial, jurídico, fiscal e de licenciamento.
BILLING_APPROVAL_REFERENCE=

# Fastify: limites seguros e compatibilidade temporaria. Rotas antigas ficam desligadas por padrao.
HTTP_BODY_LIMIT_BYTES=1000000
HTTP_REQUEST_TIMEOUT_MS=15000
HTTP_RATE_LIMIT_MAX=120
HTTP_RATE_LIMIT_WINDOW=1 minute
HTTP_TRUST_PROXY_HOPS=1
READINESS_TIMEOUT_MS=1500
SHUTDOWN_GRACE_PERIOD_MS=25000
APP_RELEASE=development
# Seed operacional do treino, avaliacao e backtest. Sobrescrevivel por job auditado.
MLOPS_SEED=2026
OTEL_SERVICE_NAME=betintel-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
SENTRY_DSN=
METRICS_BEARER_TOKEN=
ENABLE_LEGACY_HTTP_ROUTES=false

# Redis distribuido e BullMQ. Em producao, use Redis BullMQ dedicado com noeviction.
REDIS_URL=redis://127.0.0.1:6379
BULLMQ_REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=betintel:development
WORKER_DATABASE_URL=postgresql://betintel_worker:change-me@127.0.0.1:5432/betintel
SCHEDULER_DATABASE_URL=postgresql://betintel_scheduler:change-me@127.0.0.1:5432/betintel
WORKER_QUEUES=ingestion,normalization,training,evaluation,backtest,maintenance
JOB_DISPATCH_INTERVAL_MS=1000
INGESTION_SCHEDULER_INTERVAL_MS=3600000
API_FOOTBALL_DAILY_QUOTA=100
API_FOOTBALL_MONTHLY_QUOTA=3000
FOOTBALL_DATA_DAILY_QUOTA=1000
FOOTBALL_DATA_MONTHLY_QUOTA=30000
FOOTBALL_DATA_ORG_DAILY_QUOTA=1000
FOOTBALL_DATA_ORG_MONTHLY_QUOTA=30000
PROVIDER_QUOTA_ALERT_PERCENT=80
SPORTS_FIXTURE_FRESHNESS_MS=21600000
SPORTS_LIVE_FRESHNESS_MS=300000
SPORTS_PROVIDER_CACHE_TTL_MS=60000

# Variaveis publicas da SPA (nunca coloque client secret no frontend).
VITE_AUTH0_DOMAIN=seu-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://api.betintel.example/v1
VITE_AUTH0_REDIRECT_URI=https://app.betintel.example
# Flag operacional explícita; erros comuns de API continuam aparecendo como erro.
VITE_OPERATIONAL_UNAVAILABLE=false
VITE_OPERATIONAL_UNAVAILABLE_MESSAGE=
# Opcional. Sem valor, o frontend não inventa um canal de atendimento.
VITE_SUPPORT_EMAIL=
VITE_STATUS_PAGE_URL=
